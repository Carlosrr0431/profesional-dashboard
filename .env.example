VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Maps Platform — clave usada en el servidor (no exponer al navegador)
# Habilitar en Google Cloud: Places API (New)
# Solo se usa Basic Data / IDs.
# Para POIs (ej: "jaraba", "shopping") conviene dejarlo en true.
# Si querés operar 100% OSM/Nominatim, ponelo en false.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_POI_AUTOCOMPLETE_ENABLED=true

# TomTom Search + Routing API (fallback de último recurso para POIs)
TOMTOM_API_KEY=your-tomtom-api-key

# MapLibre — dejar vacío para Carto Voyager raster (recomendado en producción).
# Solo configurar si querés un estilo vectorial externo completo.
# NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Simulador GPS (solo desarrollo): chofer a simular (1 = Juan Pérez por defecto)
EMULATOR_SIM_DRIVER_NUMBER=1
# EMULATOR_SIM_DRIVER_ID=uuid-del-chofer

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nABC...\\n-----END PRIVATE KEY-----\\n"
OPENAI_API_KEY=your-openai-key
# DeepSeek — intención de viaje y normalización de direcciones (requerido)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Opcional: proyecto Supabase con tabla chats/messages (análisis de patrones)
# KNOWLEDGE_SUPABASE_URL=
# KNOWLEDGE_SUPABASE_ANON_KEY=
WASENDER_API_KEY=your-wasender-api-key
WASENDER_BASE_URL=https://www.wasenderapi.com/api
WHATSAPP_ALLOWED_PHONES=
WHATSAPP_ACCUMULATION_MS=40000
API_PORT=8787
CRON_SECRET=
WHATSAPP_TRIP_TRANSITION_SECRET=

